# Copy this file to .env and fill in the values.

# Discord Application -> Bot -> Token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# Target Discord channel for alerts (right-click a channel -> Copy Channel ID,
# requires Developer Mode enabled in Discord's settings)
DISCORD_CHANNEL_ID=

# Home Assistant WebSocket API. Use ws:// on a local/private network, wss://
# if going through a public HTTPS reverse proxy.
HA_URL=ws://localhost:8123/api/websocket

# Home Assistant long-lived access token: create one in Home Assistant under
# your profile -> Security -> Long-lived access tokens.
HA_TOKEN=

# Power sensor thresholds, in whatever unit your sensors report (usually W).
POWER_WARN_THRESHOLD_W=1500
POWER_CRIT_THRESHOLD_W=2000
